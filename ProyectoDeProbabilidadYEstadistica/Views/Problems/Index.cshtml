@{
    ViewData["Title"] = "Problemas Guiados";
}

<section class="content-card">
    <div class="content-card__header">
        <span class="eyebrow">Coleccion de ejercicios</span>
        <h1 class="section-title mb-2">Problemas de normal estandar y t-student</h1>
        <p class="muted-copy mb-0">Para calcular la respuesta al momento y desplegarla con una animacion de dropdown.</p>
    </div>

    <div class="problem-section">
        <div class="problem-section__header">
            <div class="feature-card__icon">Z</div>
            <div>
                <h2 class="problem-section__title">Distribucion normal</h2>
                <p class="muted-copy mb-0">Probabilidades, percentiles y rangos usando transformacion a normal estandar.</p>
            </div>
        </div>

        <div class="problem-grid">
            <article class="problem-card" data-problem-card>
                <div class="problem-card__head">
                    <span class="problem-card__badge">Normal 1</span>
                    <strong>Paquetes de cafe</strong>
                </div>
                <p class="problem-card__statement">
                    Los pesos de los paquetes de cafe que empaca una maquina siguen una distribucion normal con media 500 gramos y desviacion estandar 8 gramos.
                    a) Cual es la probabilidad de que un paquete pese menos de 492 gramos?
                    b) Cual es la probabilidad de que un paquete pese entre 490 y 510 gramos?
                </p>
                <button type="button" class="btn btn-primary problem-card__action" data-problem-id="normal-1">Ver respuesta</button>
                <div class="problem-answer" data-answer-panel hidden>
                    <div class="problem-answer__body" data-answer-content></div>
                </div>
            </article>

            <article class="problem-card" data-problem-card>
                <div class="problem-card__head">
                    <span class="problem-card__badge">Normal 2</span>
                    <strong>Top 10% en examen</strong>
                </div>
                <p class="problem-card__statement">
                    Las calificaciones en un examen de matematicas siguen una distribucion normal con media 78 y desviacion estandar 9.5.
                    Cual es la calificacion minima para estar en el 10% superior de los estudiantes?
                </p>
                <button type="button" class="btn btn-primary problem-card__action" data-problem-id="normal-2">Ver respuesta</button>
                <div class="problem-answer" data-answer-panel hidden>
                    <div class="problem-answer__body" data-answer-content></div>
                </div>
            </article>

            <article class="problem-card" data-problem-card>
                <div class="problem-card__head">
                    <span class="problem-card__badge">Normal 3</span>
                    <strong>Vida de focos LED</strong>
                </div>
                <p class="problem-card__statement">
                    El tiempo de vida de focos LED sigue una distribucion normal con media 1200 horas y desviacion estandar 150 horas.
                    Cual es la probabilidad de que un foco dure mas de 1400 horas?
                </p>
                <button type="button" class="btn btn-primary problem-card__action" data-problem-id="normal-3">Ver respuesta</button>
                <div class="problem-answer" data-answer-panel hidden>
                    <div class="problem-answer__body" data-answer-content></div>
                </div>
            </article>

            <article class="problem-card" data-problem-card>
                <div class="problem-card__head">
                    <span class="problem-card__badge">Normal 4</span>
                    <strong>Control de diametro</strong>
                </div>
                <p class="problem-card__statement">
                    El diametro de las bolas de rodamiento producidas sigue una distribucion normal con media 2.5 cm y desviacion estandar 0.02 cm.
                    La especificacion de calidad requiere que el diametro este entre 2.46 cm y 2.54 cm. Que porcentaje de las bolas cumple con la especificacion?
                </p>
                <button type="button" class="btn btn-primary problem-card__action" data-problem-id="normal-4">Ver respuesta</button>
                <div class="problem-answer" data-answer-panel hidden>
                    <div class="problem-answer__body" data-answer-content></div>
                </div>
            </article>

            <article class="problem-card" data-problem-card>
                <div class="problem-card__head">
                    <span class="problem-card__badge">Normal 5</span>
                    <strong>Ventas diarias</strong>
                </div>
                <p class="problem-card__statement">
                    El monto de ventas diarias de una tienda sigue una distribucion normal con media 18,500 y desviacion estandar 2,300.
                    Cual es la probabilidad de que las ventas de un dia esten por debajo de 15,000?
                </p>
                <button type="button" class="btn btn-primary problem-card__action" data-problem-id="normal-5">Ver respuesta</button>
                <div class="problem-answer" data-answer-panel hidden>
                    <div class="problem-answer__body" data-answer-content></div>
                </div>
            </article>
        </div>
    </div>

    <div class="problem-section">
        <div class="problem-section__header">
            <div class="feature-card__icon">T</div>
            <div>
                <h2 class="problem-section__title">Distribucion t-student</h2>
                <p class="muted-copy mb-0">Intervalos de confianza y pruebas de hipotesis de una muestra.</p>
            </div>
        </div>

        <div class="problem-grid">
            <article class="problem-card" data-problem-card>
                <div class="problem-card__head">
                    <span class="problem-card__badge">T 1</span>
                    <strong>Estatura universitaria</strong>
                </div>
                <p class="problem-card__statement">
                    Se toma una muestra aleatoria de 16 estudiantes de una universidad y se obtiene una media de estatura de 1.72 m.
                    Se sabe que la desviacion estandar muestral es 0.08 m. Construye un intervalo de confianza del 95% para la estatura media de todos los estudiantes.
                </p>
                <button type="button" class="btn btn-primary problem-card__action" data-problem-id="t-1">Ver respuesta</button>
                <div class="problem-answer" data-answer-panel hidden>
                    <div class="problem-answer__body" data-answer-content></div>
                </div>
            </article>

            <article class="problem-card" data-problem-card>
                <div class="problem-card__head">
                    <span class="problem-card__badge">T 2</span>
                    <strong>Baterias del fabricante</strong>
                </div>
                <p class="problem-card__statement">
                    Un fabricante afirma que el tiempo medio de duracion de sus baterias es de 45 horas. Se prueba una muestra de 25 baterias y se obtiene una media de 42.8 horas con desviacion estandar muestral de 4.2 horas.
                    Existe evidencia suficiente con alpha 0.05 para rechazar la afirmacion del fabricante en una prueba bilateral?
                </p>
                <button type="button" class="btn btn-primary problem-card__action" data-problem-id="t-2">Ver respuesta</button>
                <div class="problem-answer" data-answer-panel hidden>
                    <div class="problem-answer__body" data-answer-content></div>
                </div>
            </article>

            <article class="problem-card" data-problem-card>
                <div class="problem-card__head">
                    <span class="problem-card__badge">T 3</span>
                    <strong>Peso de paquetes</strong>
                </div>
                <p class="problem-card__statement">
                    Se desea estimar el peso promedio de los paquetes enviados por una empresa. Se toma una muestra de 12 paquetes con media 3.85 kg y desviacion estandar muestral 0.45 kg.
                    Encuentra el intervalo de confianza del 90% para el peso promedio.
                </p>
                <button type="button" class="btn btn-primary problem-card__action" data-problem-id="t-3">Ver respuesta</button>
                <div class="problem-answer" data-answer-panel hidden>
                    <div class="problem-answer__body" data-answer-content></div>
                </div>
            </article>

            <article class="problem-card" data-problem-card>
                <div class="problem-card__head">
                    <span class="problem-card__badge">T 4</span>
                    <strong>Contaminante en agua</strong>
                </div>
                <p class="problem-card__statement">
                    Un investigador mide la concentracion de un contaminante en 10 muestras de agua y obtiene media 28.4 y desviacion estandar muestral 6.8.
                    Prueba la hipotesis de que la concentracion media es mayor a 25 mg/L con alpha 0.05 en una prueba unilateral derecha.
                </p>
                <button type="button" class="btn btn-primary problem-card__action" data-problem-id="t-4">Ver respuesta</button>
                <div class="problem-answer" data-answer-panel hidden>
                    <div class="problem-answer__body" data-answer-content></div>
                </div>
            </article>

            <article class="problem-card" data-problem-card>
                <div class="problem-card__head">
                    <span class="problem-card__badge">T 5</span>
                    <strong>Tiempo para resolver</strong>
                </div>
                <p class="problem-card__statement">
                    Se quiere estimar la media de tiempo en minutos que tardan los estudiantes en resolver un problema de estadistica.
                    Se toma una muestra de 20 estudiantes con media 18.5 minutos y desviacion estandar muestral 5.2 minutos. Construye un intervalo de confianza del 99% para el tiempo medio.
                </p>
                <button type="button" class="btn btn-primary problem-card__action" data-problem-id="t-5">Ver respuesta</button>
                <div class="problem-answer" data-answer-panel hidden>
                    <div class="problem-answer__body" data-answer-content></div>
                </div>
            </article>
        </div>
    </div>
</section>

@section Scripts {
    <script>
        (() => {
            const format = (value, digits = 4) => Number(value).toFixed(digits);
            const percent = (value, digits = 2) => `${(Number(value) * 100).toFixed(digits)}%`;
            const cards = document.querySelectorAll('[data-problem-card]');

            const standardize = (x, mean, sigma) => (x - mean) / sigma;

            const createSyntheticSample = (n, mean, sampleDeviation) => {
                const deviation = sampleDeviation * Math.sqrt((n - 1) / 2);
                const values = Array.from({ length: n }, () => mean);
                values[0] = mean + deviation;
                values[1] = mean - deviation;
                return values;
            };

            const normalRequest = (payload) => fetch('/api/standard-normal/calculate', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(payload)
            }).then(async response => {
                if (!response.ok) {
                    throw new Error('No fue posible calcular la distribucion normal.');
                }

                return response.json();
            });

            const tRequest = (payload) => fetch('/api/t-student/calculate', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(payload)
            }).then(async response => {
                if (!response.ok) {
                    throw new Error('No fue posible calcular la distribucion t-student.');
                }

                return response.json();
            });

            const renderMetricGrid = (items) => `
                <div class="problem-answer__grid">
                    ${items.map(item => `
                        <div class="problem-answer__metric">
                            <span>${item.label}</span>
                            <strong>${item.value}</strong>
                        </div>
                    `).join('')}
                </div>
            `;

            const solveProblem = async (problemId) => {
                switch (problemId) {
                    case 'normal-1': {
                        const lessThan = await normalRequest({
                            calculationMode: 'from-z',
                            zValue: standardize(492, 500, 8),
                            areaSide: 'left'
                        });
                        const lower = await normalRequest({
                            calculationMode: 'from-z',
                            zValue: standardize(490, 500, 8),
                            areaSide: 'left'
                        });
                        const upper = await normalRequest({
                            calculationMode: 'from-z',
                            zValue: standardize(510, 500, 8),
                            areaSide: 'left'
                        });

                        return `
                            <p>Se transforma cada valor a <code>z = (x - mu) / sigma</code>. Para 492 gramos, <code>z = -1</code>. Para el rango 490 a 510, los valores son <code>z = -1.25</code> y <code>z = 1.25</code>.</p>
                            ${renderMetricGrid([
                                { label: 'P(X < 492)', value: percent(lessThan.area) },
                                { label: 'P(490 < X < 510)', value: percent(upper.area - lower.area) }
                            ])}
                        `;
                    }
                    case 'normal-2': {
                        const result = await normalRequest({
                            calculationMode: 'from-area',
                            areaValue: 0.9,
                            areaSide: 'left'
                        });
                        const score = 78 + (result.zValue * 9.5);

                        return `
                            <p>Estar en el 10% superior significa dejar 90% del area a la izquierda. El valor de <code>z</code> asociado a esa area y luego se regresa a la escala original.</p>
                            ${renderMetricGrid([
                                { label: 'Valor z', value: format(result.zValue, 3) },
                                { label: 'Calificacion minima', value: format(score, 2) }
                            ])}
                        `;
                    }
                    case 'normal-3': {
                        const result = await normalRequest({
                            calculationMode: 'from-z',
                            zValue: standardize(1400, 1200, 150),
                            areaSide: 'right'
                        });

                        return `
                            <p>Para 1400 horas, el valor estandarizado es <code>z = 1.333</code>. Se toma el area a la derecha porque se pregunta por una duracion mayor a 1400.</p>
                            ${renderMetricGrid([
                                { label: 'Valor z', value: format(result.zValue, 3) },
                                { label: 'P(X > 1400)', value: percent(result.area) }
                            ])}
                        `;
                    }
                    case 'normal-4': {
                        const lower = await normalRequest({
                            calculationMode: 'from-z',
                            zValue: standardize(2.46, 2.5, 0.02),
                            areaSide: 'left'
                        });
                        const upper = await normalRequest({
                            calculationMode: 'from-z',
                            zValue: standardize(2.54, 2.5, 0.02),
                            areaSide: 'left'
                        });
                        const within = upper.area - lower.area;

                        return `
                            <p>Los limites de especificacion equivalen a <code>z = -2</code> y <code>z = 2</code>. El porcentaje dentro de especificacion es el area acumulada entre ambos valores.</p>
                            ${renderMetricGrid([
                                { label: 'Area entre limites', value: percent(within) },
                                { label: 'Cumplen especificacion', value: percent(within) }
                            ])}
                        `;
                    }
                    case 'normal-5': {
                        const result = await normalRequest({
                            calculationMode: 'from-z',
                            zValue: standardize(15000, 18500, 2300),
                            areaSide: 'left'
                        });

                        return `
                            <p>El monto de 15,000 se estandariza y se evalua el area acumulada a la izquierda para obtener la probabilidad pedida.</p>
                            ${renderMetricGrid([
                                { label: 'Valor z', value: format(result.zValue, 3) },
                                { label: 'P(X < 15000)', value: percent(result.area) }
                            ])}
                        `;
                    }
                    case 't-1': {
                        const result = await tRequest({
                            values: createSyntheticSample(16, 1.72, 0.08),
                            hypothesizedMean: 1.72,
                            alpha: 0.05,
                            testType: 'two-tailed'
                        });

                        return `
                            <p>Se arma una muestra sintetica equivalente con <code>n = 16</code>, media <code>1.72</code> y desviacion muestral <code>0.08</code>, suficiente para reproducir el mismo intervalo de confianza.</p>
                            ${renderMetricGrid([
                                { label: 'IC 95% inferior', value: `${format(result.confidenceIntervalLower, 4)} m` },
                                { label: 'IC 95% superior', value: `${format(result.confidenceIntervalUpper, 4)} m` },
                                { label: 'Grados de libertad', value: result.degreesOfFreedom }
                            ])}
                        `;
                    }
                    case 't-2': {
                        const result = await tRequest({
                            values: createSyntheticSample(25, 42.8, 4.2),
                            hypothesizedMean: 45,
                            alpha: 0.05,
                            testType: 'two-tailed'
                        });

                        return `
                            <p>La prueba bilateral contrasta <code>H0: mu = 45</code> contra <code>H1: mu != 45</code>. La decision se toma con el <code>p-value</code> y el nivel de significancia de 0.05.</p>
                            ${renderMetricGrid([
                                { label: 'Estadistico t', value: format(result.tStatistic, 3) },
                                { label: 'P-value', value: format(result.pValue, 4) },
                                { label: 'Conclusion', value: result.conclusion }
                            ])}
                        `;
                    }
                    case 't-3': {
                        const result = await tRequest({
                            values: createSyntheticSample(12, 3.85, 0.45),
                            hypothesizedMean: 3.85,
                            alpha: 0.10,
                            testType: 'two-tailed'
                        });

                        return `
                            <p>Un intervalo de confianza del 90% corresponde a <code>alpha = 0.10</code></p>
                            ${renderMetricGrid([
                                { label: 'IC 90% inferior', value: `${format(result.confidenceIntervalLower, 4)} kg` },
                                { label: 'IC 90% superior', value: `${format(result.confidenceIntervalUpper, 4)} kg` },
                                { label: 'Grados de libertad', value: result.degreesOfFreedom }
                            ])}
                        `;
                    }
                    case 't-4': {
                        const result = await tRequest({
                            values: createSyntheticSample(10, 28.4, 6.8),
                            hypothesizedMean: 25,
                            alpha: 0.05,
                            testType: 'right-tailed'
                        });

                        return `
                            <p>La hipotesis alternativa es <code>mu &gt; 25</code>, por lo que se usa una prueba unilateral derecha. La evidencia se resume en el estadistico t y el <code>p-value</code>.</p>
                            ${renderMetricGrid([
                                { label: 'Estadistico t', value: format(result.tStatistic, 3) },
                                { label: 'P-value', value: format(result.pValue, 4) },
                                { label: 'Conclusion', value: result.conclusion }
                            ])}
                        `;
                    }
                    case 't-5': {
                        const result = await tRequest({
                            values: createSyntheticSample(20, 18.5, 5.2),
                            hypothesizedMean: 18.5,
                            alpha: 0.01,
                            testType: 'two-tailed'
                        });

                        return `
                            <p>Un intervalo de confianza del 99% corresponde a <code>alpha = 0.01</code>. Se conserva la media y la desviacion muestral del problema mediante una muestra sintetica equivalente.</p>
                            ${renderMetricGrid([
                                { label: 'IC 99% inferior', value: `${format(result.confidenceIntervalLower, 4)} min` },
                                { label: 'IC 99% superior', value: `${format(result.confidenceIntervalUpper, 4)} min` },
                                { label: 'Grados de libertad', value: result.degreesOfFreedom }
                            ])}
                        `;
                    }
                    default:
                        throw new Error('Problema no configurado.');
                }
            };

            const expandPanel = (panel) => {
                panel.hidden = false;
                requestAnimationFrame(() => {
                    panel.classList.add('is-open');
                    panel.style.maxHeight = `${panel.scrollHeight}px`;
                });
            };

            const collapsePanel = (panel) => {
                panel.style.maxHeight = `${panel.scrollHeight}px`;
                requestAnimationFrame(() => {
                    panel.classList.remove('is-open');
                    panel.style.maxHeight = '0px';
                });

                panel.addEventListener('transitionend', () => {
                    if (!panel.classList.contains('is-open')) {
                        panel.hidden = true;
                    }
                }, { once: true });
            };

            cards.forEach(card => {
                const button = card.querySelector('.problem-card__action');
                const panel = card.querySelector('[data-answer-panel]');
                const content = card.querySelector('[data-answer-content]');

                button.addEventListener('click', async () => {
                    const isOpen = panel.classList.contains('is-open');

                    if (isOpen) {
                        collapsePanel(panel);
                        button.textContent = 'Ver respuesta';
                        return;
                    }

                    if (!card.dataset.loaded) {
                        button.disabled = true;
                        button.textContent = 'Calculando...';

                        try {
                            content.innerHTML = await solveProblem(button.dataset.problemId);
                            card.dataset.loaded = 'true';
                        } catch (error) {
                            content.innerHTML = `<p class="mb-0 text-danger">${error.message}</p>`;
                        } finally {
                            button.disabled = false;
                        }
                    }

                    expandPanel(panel);
                    button.textContent = 'Ocultar respuesta';
                });
            });
        })();
    </script>
}
