@{
    ViewData["Title"] = "Privacidad";
}

<section class="content-card content-card--narrow">
    <div class="content-card__header">
        <span class="eyebrow">Informacion</span>
        <h1 class="section-title mb-2">@ViewData["Title"]</h1>
        <p class="muted-copy mb-0">Esta aplicacion academica procesa los datos ingresados para realizar calculos estadisticos y generar visualizaciones dentro de la misma sesion.</p>
    </div>

    <div class="metric-panel">
        <span class="metric-label">Uso de datos</span>
        <strong class="metric-value">Los valores enviados se usan solo para calcular resultados y no forman parte de un flujo comercial.</strong>
    </div>
</section>
